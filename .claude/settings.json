{
  "permissions": {
    "allow": [
      "Bash(make:*)",
      "Bash(uv run:*)",
      "Bash(uv lock:*)",
      "Bash(uv sync:*)",
      "Bash(uv add:*)",
      "Bash(git:*)",
      "Bash(gh:*)",
      "WebSearch",
      "Skill(commit-push-pr)",
      "Skill(pr-review-toolkit:review-pr)"
    ]
  },
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Write|Edit",
        "hooks": [
          {
            "type": "command",
            "command": "uv run ruff format"
          }
        ]
      }
    ]
  },
  "enabledPlugins": {
    "code-simplifier@claude-plugins-official": true,
    "pr-review-toolkit@claude-plugins-official": true
  }
}
